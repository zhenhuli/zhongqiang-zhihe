# ============================================
# Git 属性配置
# 处理换行符、文本文件检测等
# ============================================

# 文本文件自动转换换行符
* text=auto

# ============================================
# 源代码文件
# ============================================

# JavaScript/TypeScript
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.d.ts text eol=lf

# Vue
*.vue text eol=lf

# CSS/样式
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf
*.less text eol=lf
*.styl text eol=lf

# HTML
*.html text eol=lf
*.htm text eol=lf

# JSON
*.json text eol=lf
*.jsonc text eol=lf
*.json5 text eol=lf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# XML
*.xml text eol=lf
*.svg text eol=lf

# ============================================
# 配置文件
# ============================================

*.gitignore text eol=lf
*.gitattributes text eol=lf
*.npmrc text eol=lf
*.env text eol=lf
*.env.* text eol=lf

# ============================================
# 二进制文件 (不处理换行符)
# ============================================

# 图片
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.webp binary
*.ico binary

# 字体
*.eot binary
*.otf binary
*.ttf binary
*.woff binary
*.woff2 binary

# 压缩包
*.zip binary
*.tar binary
*.gz binary
*.rar binary

# 可执行文件
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# 文档
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary

# 其他二进制文件
*.lock binary
pnpm-lock.yaml binary
