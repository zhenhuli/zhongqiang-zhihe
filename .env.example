# ============================================
# 环境变量示例文件
# 复制此文件为 .env 并填入实际值
# ============================================

# ============================================
# 通用配置
# ============================================

# 运行环境: development | production | test
NODE_ENV=development

# API 基础路径
VITE_API_BASE_URL=http://localhost:4000

# ============================================
# Node.js 服务配置 (apps/node-service)
# ============================================

# 服务端口
PORT=4000

# ============================================
# 数据库配置
# ============================================

# MySQL 配置 (示例)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=zhongqiang

# PostgreSQL 配置 (示例)
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=your_password
# PG_DATABASE=zhongqiang

# Redis 配置 (示例)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================
# JWT 配置
# ============================================

# JWT 密钥
# JWT_SECRET=your-super-secret-jwt-key-change-in-production
# JWT_EXPIRES_IN=7d

# ============================================
# 第三方服务配置
# ============================================

# 阿里云 OSS (示例)
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_OSS_BUCKET=
# ALIYUN_OSS_REGION=

# 微信小程序 (示例)
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=

# 短信服务 (示例)
# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=
